---
/* src/components/ComingSoon.astro */
---

<div class="coming-soon-wrapper fade-in">
  <div class="bg-container">
    <div class="bg-overlay"></div>
  </div>

  <main class="content">
    <div class="brand-header">
      <div class="logo-container">
        <img src="/logo.svg" alt="La Lucha Sanguchería" class="logo" />
      </div>

      <div class="title-container">
        <img src="/proximamente.svg" alt="PRÓXIMAMENTE" class="title-img" />
      </div>
    </div>

    <div class="button-group slide-up">
      <a href="#" class="btn btn-1" aria-label="Ir a Facturación">
        <img src="/facturacion.svg" alt="FACTURACIÓN" class="btn-text-img img-facturacion" />
      </a>
      <a href="#" class="btn btn-2" aria-label="Ir a Libro de Reclamaciones">
        <img src="/libro-reclamaciones.svg" alt="LIBRO DE RECLAMACIONES" class="btn-text-img img-reclamaciones" />
      </a>
    </div>
  </main>
</div>

<style>
  .coming-soon-wrapper {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 3rem 2rem;
    position: relative;
    z-index: 1;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center; /* Brand in center */
    text-align: center;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .brand-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0; /* Extremely tight gap */
    transform: translateY(-10%); /* Lift slightly from dead center */
  }

  .logo-container {
    width: clamp(140px, 15vw, 200px);
  }

  .logo {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
  }

  .title-container {
    width: clamp(250px, 30vw, 600px);
    margin-top: 1rem; /* Overlap slightly with logo as in image */
  }

  .title-img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 4px 15px rgba(0,0,0,0.6));
  }

  .button-group {
    position: absolute;
    bottom: 4rem;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 0 1rem;
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.3s ease;
    height: 34px; /* Slimmer buttons as in image */
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  .btn-1 {
    width: 160px;
    background-image: url('/boton1.png');
  }

  .btn-2 {
    width: 250px;
    background-image: url('/boton2.png');
  }

  .btn:hover {
    transform: scale(1.08);
    filter: brightness(1.25) contrast(1.1);
  }

  .btn-text-img {
    width: auto;
    display: block;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));
  }

  /* Clases específicas para que puedas ajustar los tamaños individualmente */
  .img-facturacion {
    height: 38%;
  }

  .img-reclamaciones {
    height: 31%;
  }

  @media (max-width: 768px) {
    .coming-soon-wrapper {
      padding: 4rem 1.5rem;
    }

    .button-group {
      bottom: 2rem;
      gap: 1rem;
    }

    .img-facturacion {
      height: 38%;
    }

    .img-reclamaciones {
      height: 31%;
    }
  }

  @media (max-height: 650px) {
    .content {
      gap: 0.5rem;
    }
    .logo-container {
      width: 110px;
    }
    .title-container {
      width: 200px;
    }
    .button-group {
      margin-top: auto;
    }
  }
</style>
