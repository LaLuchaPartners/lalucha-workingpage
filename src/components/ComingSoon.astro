---
/* src/components/ComingSoon.astro */
---

<div class="coming-soon-wrapper fade-in">
  <div class="bg-container">
    <div class="bg-overlay"></div>
  </div>

  <main class="content">
    <div class="logo-container">
      <img src="/logo.svg" alt="La Lucha Sanguchería" class="logo" />
    </div>

    <div class="title-container">
      <img src="/proximamente.svg" alt="PRÓXIMAMENTE" class="title-img" />
    </div>

    <div class="button-group slide-up">
      <a href="#" class="btn btn-1" aria-label="Ir a Facturación">
        <img src="/facturacion.svg" alt="FACTURACIÓN" class="btn-text-img" />
      </a>
      <a href="#" class="btn btn-2" aria-label="Ir a Libro de Reclamaciones">
        <img src="/libro-reclamaciones.svg" alt="LIBRO DE RECLAMACIONES" class="btn-text-img" />
      </a>
    </div>
  </main>
</div>

<style>
  .coming-soon-wrapper {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 3rem 2rem;
    position: relative;
    z-index: 1;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    width: 100%;
    height: 100%;
  }

  .logo-container {
    width: clamp(140px, 18vw, 220px);
    margin-top: auto; /* Push logo/title part to the center by balancing with bottom margin */
  }

  .logo {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
  }

  .title-container {
    width: clamp(240px, 40vw, 480px);
    margin-bottom: 2rem;
  }

  .title-img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 4px 15px rgba(0,0,0,0.6));
  }

  .button-group {
    display: flex;
    gap: 1.5rem;
    margin-top: auto; /* Push to the bottom */
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.3s ease;
    min-width: 180px;
    height: 42px;
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
    padding: 0 1.5rem;
  }

  .btn-1 {
    background-image: url('/boton1.png');
  }

  .btn-2 {
    background-image: url('/boton2.png');
  }

  .btn:hover {
    transform: scale(1.08);
    filter: brightness(1.25) contrast(1.1);
  }

  .btn-text-img {
    height: 30%; 
    width: auto;
    display: block;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));
  }

  @media (max-width: 768px) {
    .coming-soon-wrapper {
      padding: 4rem 1.5rem;
    }

    .button-group {
      flex-direction: column;
      gap: 1rem;
      margin-top: auto;
      align-items: center;
    }
    
    .logo-container {
      width: clamp(120px, 25vw, 180px);
    }

    .title-container {
      width: clamp(200px, 70vw, 350px);
    }

    .btn {
      min-width: 200px;
      height: 48px;
    }

    .btn-text-img {
      height: 35%;
    }
  }

  @media (max-height: 650px) {
    .content {
      gap: 0.5rem;
    }
    .logo-container {
      width: 110px;
    }
    .title-container {
      width: 200px;
    }
    .button-group {
      margin-top: auto;
    }
  }
</style>
